# Personal Agent Environment Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# LLM Provider Configuration (choose one)
# ===========================================

# Option 1: OpenAI (default)
OPENAI_API_KEY=sk-your-openai-api-key-here
API_BASE_URL=https://api.openai.com/v1

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option 3: Ollama (local models)
# OLLAMA_BASE_URL=http://localhost:11434
# API_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama

# Option 4: Any OpenAI-compatible provider (e.g., DeepSeek, Qwen)
# OPENAI_API_KEY=your-key-here
# API_BASE_URL=https://api.deepseek.com/v1

# ===========================================
# Relay Mode LLM Configuration
# ===========================================
# relay-cli.ts supports switching between Anthropic native API
# and any OpenAI-compatible API (Volcengine Ark, DeepSeek, Qwen, etc.)
#
# Provider selector: anthropic | openai (default: anthropic)
# LLM_PROVIDER=anthropic
#
# --- Anthropic mode ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=  (optional, for proxy)
#
# --- OpenAI-compatible mode (火山引擎方舟 / DeepSeek / 通义千问) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-volcengine-api-key
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENAI_MODEL=doubao-pro-32k
#
# DeepSeek example:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ===========================================
# Model Configuration
# ===========================================
# Default model (adjust based on your provider)
# For OpenAI: gpt-4o, gpt-4o-mini, o1, etc.
# For Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514
# PA_MODEL=gpt-4o

# ===========================================
# Feature Flags
# ===========================================
# Disable telemetry and analytics
CLAUDE_CODE_ATTRIBUTION_HEADER=false
CLAUDE_CODE_SIMPLE=true

# Disable OAuth (Personal Agent uses API key only)
# CLAUDE_CODE_USE_BEDROCK=false
# CLAUDE_CODE_USE_VERTEX=false
# CLAUDE_CODE_USE_FOUNDRY=false

# ===========================================
# Finance Data Tools (Phase 3)
# ===========================================
# YAHOO_FINANCE_API_KEY=
# EASTMONEY_COOKIE=
# ALPHA_VANTAGE_KEY=

# ===========================================
# Monitoring Configuration
# ===========================================
# MONITOR_INTERVAL_MS=60000
# ALERT_WEBHOOK_URL=

# ===========================================
# Quant Strategy Engine (Phase 4)
# ===========================================
# DEFAULT_BROKER=simulated
# RISK_MAX_POSITION_PCT=10
# MAX_DAILY_LOSS_PCT=2
