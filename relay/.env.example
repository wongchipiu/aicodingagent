# Personal Agent Relay Server 配置模板
# 复制为 .env 并修改值

# === 必填 ===
PA_RELAY_KEY=change-this-to-your-secret-key

# === 中继服务器 ===
PA_RELAY_PORT=7780
PA_RELAY_HOST=0.0.0.0

# === JWT 认证 ===
PA_TOKEN_TTL_SEC=86400

# === 心跳 ===
PA_HEARTBEAT_TIMEOUT_SEC=90
PA_HEARTBEAT_CHECK_INTERVAL_SEC=30

# === 配对码 ===
PA_PAIR_CODE_TTL_SEC=300

# === 会话 ===
PA_MAX_SESSIONS=10

# === CORS ===
PA_ENABLE_CORS=true

# === CLI 端配置 (PC 上运行 pa remote-relay 时使用) ===
# PA_RELAY_URL=http://your-server-ip:7780
# PA_RELAY_KEY=change-this-to-your-secret-key

# === LLM 配置 (Personal Agent 本体) ===
# OPENAI_API_KEY=sk-your-openai-key
# API_BASE_URL=https://api.openai.com/v1
